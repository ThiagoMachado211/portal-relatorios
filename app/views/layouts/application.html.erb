<!DOCTYPE html>
<html>
  <head>
    <title>PortalRelatorios</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="app-wrapper">
        <div class="app-shell">
          <aside class="sidebar">
            <div class="sidebar-brand">
              <div class="sidebar-logo">EP</div>
              <div>
                <div class="sidebar-title">EstudoPlay</div>
                <div class="sidebar-subtitle">Portal de Relatórios</div>
              </div>
            </div>

            <nav class="sidebar-nav">
              <%= link_to "Dashboard", dashboard_path, class: "sidebar-link" %>

              <% SidebarSection.active.ordered.includes(:sidebar_subsections).each do |section| %>
                <div data-controller="sidebar-toggle">
                  <button
                    type="button"
                    class="sidebar-link sidebar-toggle-button"
                    data-action="click->sidebar-toggle#toggle"
                    style="width:100%;text-align:left;border:none;background:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;">
                    <span><%= section.title %></span>
                    <span data-sidebar-toggle-target="icon">▸</span>
                  </button>

                  <div data-sidebar-toggle-target="children" class="hidden sidebar-children-container">
                    <% section.sidebar_subsections.active.ordered.each do |subsection| %>
                      <%= link_to subsection.title,
                          report_subsection_path(section.slug, subsection.slug),
                          class: "sidebar-link sidebar-subsection-level-2" %>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <% if current_user.admin? %>
                <hr style="border:none;border-top:1px solid rgba(255,255,255,0.12);margin:16px 0;">

                <%= link_to "Admin - Seções", admin_sidebar_sections_path, class: "sidebar-link" %>
                <%= link_to "Admin - Subseções", admin_sidebar_subsections_path, class: "sidebar-link" %>
                <%= link_to "Admin - Conteúdos", admin_report_pages_path, class: "sidebar-link" %>
              <% end %>
            </nav>
          </aside>

          <div class="app-main">
            <header class="topbar">
              <div>
                <div class="topbar-title">Dashboard</div>
                <div class="topbar-subtitle">Acompanhe seus relatórios e indicadores</div>
              </div>

              <div class="topbar-right">
                <div class="user-pill">
                  <div class="user-avatar">
                    <%= current_user.name.to_s.first&.upcase || "U" %>
                  </div>
                  <div>
                    <div class="user-name"><%= current_user.name %></div>
                    <div class="user-role"><%= current_user.user_type %></div>
                  </div>
                </div>

                <%= button_to "Sair",
                    destroy_user_session_path,
                    method: :delete,
                    form: { class: "logout-form" },
                    class: "logout-button" %>
              </div>
            </header>

            <main class="content">
              <% if notice.present? %>
                <div class="flash flash-notice"><%= notice %></div>
              <% end %>

              <% if alert.present? %>
                <div class="flash flash-alert"><%= alert %></div>
              <% end %>

              <%= yield %>
            </main>
          </div>
        </div>
      </div>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>