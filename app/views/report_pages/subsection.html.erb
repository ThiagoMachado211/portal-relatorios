<div class="card">
  <div class="card-title">
    <%= @subsection.title %>
  </div>

  <div class="card-subtitle">
    Conteúdos disponíveis nesta subseção
  </div>

  <% if @report_pages.present? && @report_pages.any? %>
    <div class="profile-card">
      <% @report_pages.each do |page| %>
        <div class="report-item-card">
          <div class="report-item-header">
            <div class="report-item-title">
              <%= page.title %>
            </div>

            <div>
              <% if page.pdf? && page.file.attached? %>
                <%= link_to "Abrir PDF",
                    rails_storage_proxy_path(page.file, disposition: "inline"),
                    target: "_blank",
                    rel: "noopener",
                    class: "btn-primary" %>

              <% elsif page.external_link? && page.embed_url.present? %>
                <%= link_to "Abrir Link",
                    page.embed_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "btn-primary" %>

              <% elsif page.streamlit? && page.embed_url.present? %>
                <%= link_to "Abrir Dashboard",
                    page.embed_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "btn-primary" %>

              <% elsif page.file.attached? %>
                <%= link_to "Abrir Arquivo",
                    rails_storage_proxy_path(page.file, disposition: "inline"),
                    target: "_blank",
                    rel: "noopener",
                    class: "btn-primary" %>

              <% elsif page.embed_url.present? %>
                <%= link_to "Abrir Conteúdo",
                    page.embed_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "btn-primary" %>

              <% else %>
                <span class="btn-secondary" style="opacity:0.7;cursor:default;">
                  Indisponível
                </span>
              <% end %>
            </div>
          </div>

          <% if page.description.present? %>
            <div class="report-item-description">
              <%= page.description %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="profile-line">
      <div class="profile-value">
        Nenhum conteúdo disponível para esta subseção.
      </div>
    </div>
  <% end %>
</div>