<div class="card">
  <div class="card-title">Teste da subseção</div>
  <div class="card-subtitle">Se esta página abrir, a view básica está funcionando.</div>

  <div class="profile-line">
    <div class="profile-key">Seção</div>
    <div class="profile-value"><%= @section.title %></div>
  </div>

  <div class="profile-line">
    <div class="profile-key">Subseção</div>
    <div class="profile-value"><%= @subsection.title %></div>
  </div>

  <div class="profile-line">
    <div class="profile-key">Quantidade de páginas</div>
    <div class="profile-value"><%= @report_pages.count %></div>
  </div>
</div>