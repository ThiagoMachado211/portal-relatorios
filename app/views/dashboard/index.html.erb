<div class="dashboard-grid">
  <p>Último acesso: <%= @last_access_at.present? ? @last_access_at.strftime("%d/%m/%Y %H:%M") : "Sem registro" %></p>
  <p>Acessos: <%= @access_count %></p>
  <p>Última atualização: <%= @last_data_update.present? ? @last_data_update.strftime("%d/%m/%Y %H:%M") : "Sem dados" %></p>
  <p>Conteúdos: <%= @available_content_count %></p>
</div>