<div class="trip-form-page">
  <div class="trip-form-shell">
    <div class="trip-form-header">
      <div>
        <h1>Novo Registro de Viagem</h1>
        <p>Preencha os dados abaixo para adicionar uma nova viagem ao sistema.</p>
      </div>

      <div class="trip-form-header__actions">
        <%= link_to "Voltar ao dashboard", dashboard_long_trips_path, class: "trip-btn trip-btn--secondary" %>
        <%= link_to "Importar CSV", import_long_trips_path, class: "trip-btn trip-btn--dark" %>
      </div>
    </div>

    <% if @long_trip.errors.any? %>
      <div class="trip-form-errors">
        <div class="trip-form-errors__title">
          Não foi possível salvar o registro.
        </div>
        <ul>
          <% @long_trip.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @long_trip, local: true, class: "trip-form-card" do |f| %>
      <div class="trip-form-grid">
        <div class="trip-field">
          <%= f.label :travel_request_id, "ID da solicitação" %>
          <%= f.number_field :travel_request_id, class: "trip-input", placeholder: "Ex.: 1025" %>
        </div>

        <div class="trip-field">
          <%= f.label :traveler_name, "Nome do viajante" %>
          <%= f.text_field :traveler_name, class: "trip-input", placeholder: "Nome completo" %>
        </div>

        <div class="trip-field">
          <%= f.label :traveler_sector, "Setor do viajante" %>
          <%= f.text_field :traveler_sector, class: "trip-input", placeholder: "Ex.: Financeiro" %>
        </div>

        <div class="trip-field">
          <%= f.label :travel_reason, "Motivo da viagem" %>
          <%= f.text_field :travel_reason, class: "trip-input", placeholder: "Ex.: Reunião, treinamento..." %>
        </div>

        <div class="trip-field">
          <%= f.label :purchase_date, "Data da compra" %>
          <%= f.date_field :purchase_date, class: "trip-input" %>
        </div>

        <div class="trip-field">
          <%= f.label :travel_date, "Data da viagem" %>
          <%= f.date_field :travel_date, class: "trip-input" %>
        </div>

        <div class="trip-field">
          <%= f.label :transport_mode, "Modal de transporte" %>
          <%= f.select :transport_mode,
              [["Aéreo", "Aéreo"], ["Terrestre", "Terrestre"]],
              { include_blank: "Selecione" },
              class: "trip-input" %>
        </div>

        <div class="trip-field">
          <%= f.label :transport_company, "Empresa de transporte" %>
          <%= f.text_field :transport_company, class: "trip-input", placeholder: "Ex.: LATAM, GOL, Viação..." %>
        </div>

        <div class="trip-field">
          <%= f.label :origin_city, "Cidade de origem" %>
          <%= f.text_field :origin_city, class: "trip-input", placeholder: "Ex.: João Pessoa" %>
        </div>

        <div class="trip-field">
          <%= f.label :origin_state, "Estado de origem" %>
          <%= f.text_field :origin_state, class: "trip-input", placeholder: "Ex.: PB" %>
        </div>

        <div class="trip-field">
          <%= f.label :origin_terminal, "Terminal de origem" %>
          <%= f.text_field :origin_terminal, class: "trip-input", placeholder: "Aeroporto / rodoviária" %>
        </div>

        <div class="trip-field">
          <%= f.label :destination_city, "Cidade de destino" %>
          <%= f.text_field :destination_city, class: "trip-input", placeholder: "Ex.: Recife" %>
        </div>

        <div class="trip-field">
          <%= f.label :destination_state, "Estado de destino" %>
          <%= f.text_field :destination_state, class: "trip-input", placeholder: "Ex.: PE" %>
        </div>

        <div class="trip-field">
          <%= f.label :destination_terminal, "Terminal de destino" %>
          <%= f.text_field :destination_terminal, class: "trip-input", placeholder: "Aeroporto / rodoviária" %>
        </div>

        <div class="trip-field">
          <%= f.label :mileage, "Quilometragem" %>
          <%= f.number_field :mileage, step: :any, class: "trip-input", placeholder: "Ex.: 450.5" %>
        </div>

        <div class="trip-field">
          <%= f.label :purchase_value_brl, "Valor da compra (R$)" %>
          <%= f.number_field :purchase_value_brl, step: :any, class: "trip-input", placeholder: "Ex.: 1250.00" %>
        </div>

        <div class="trip-field">
          <%= f.label :purchase_value_points, "Valor da compra (pontos)" %>
          <%= f.number_field :purchase_value_points, step: :any, class: "trip-input", placeholder: "Ex.: 15000" %>
        </div>

        <div class="trip-field">
          <%= f.label :extra_fees_brl, "Taxas extras (R$)" %>
          <%= f.number_field :extra_fees_brl, step: :any, class: "trip-input", placeholder: "Ex.: 55.90" %>
        </div>

        <div class="trip-field">
          <%= f.label :refund_value_brl, "Valor reembolsado (R$)" %>
          <%= f.number_field :refund_value_brl, step: :any, class: "trip-input", placeholder: "Ex.: 300.00" %>
        </div>

        <div class="trip-field">
          <%= f.label :refund_value_points, "Valor reembolsado (pontos)" %>
          <%= f.number_field :refund_value_points, step: :any, class: "trip-input", placeholder: "Ex.: 5000" %>
        </div>
      </div>

      <div class="trip-form-section-title">Conformidade e status</div>

      <div class="trip-form-grid trip-form-grid--compact">
        <div class="trip-field trip-field--checkbox">
          <label class="trip-check">
            <%= f.check_box :policy_compliant %>
            <span>Está em conformidade com a política</span>
          </label>
        </div>

        <div class="trip-field trip-field--checkbox">
          <label class="trip-check">
            <%= f.check_box :canceled %>
            <span>Viagem cancelada</span>
          </label>
        </div>
      </div>

      <div class="trip-field">
        <%= f.label :non_compliance_reason, "Motivo de não conformidade" %>
        <%= f.text_area :non_compliance_reason, rows: 4, class: "trip-input trip-textarea", placeholder: "Descreva o motivo, caso a viagem não esteja em conformidade." %>
      </div>

      <div class="trip-form-actions">
        <%= link_to "Cancelar", dashboard_long_trips_path, class: "trip-btn trip-btn--secondary" %>
        <%= f.submit "Salvar registro", class: "trip-btn trip-btn--primary" %>
      </div>
    <% end %>
  </div>
</div>

<style>
  .trip-form-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #102caa 0%, #5fb0df 100%);
    padding: 32px 20px 60px;
  }

  .trip-form-shell {
    max-width: 1180px;
    margin: 0 auto;
  }

  .trip-form-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    margin-bottom: 24px;
    color: #fff;
  }

  .trip-form-header h1 {
    margin: 0 0 8px;
    font-size: 2.2rem;
    line-height: 1.1;
  }

  .trip-form-header p {
    margin: 0;
    font-size: 1rem;
    opacity: 0.92;
  }

  .trip-form-header__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .trip-form-card {
    background: rgba(255, 255, 255, 0.98);
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.18);
  }

  .trip-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(260px, 1fr));
    gap: 18px;
    margin-bottom: 24px;
  }

  .trip-form-grid--compact {
    grid-template-columns: repeat(2, minmax(220px, 1fr));
  }

  .trip-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .trip-field label {
    font-size: 0.95rem;
    font-weight: 700;
    color: #17306e;
  }

  .trip-input {
    width: 100%;
    min-height: 48px;
    border: 1px solid #c9d7f0;
    border-radius: 14px;
    padding: 12px 14px;
    font-size: 0.98rem;
    color: #17306e;
    background: #f8fbff;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }

  .trip-input:focus {
    border-color: #2f63ff;
    box-shadow: 0 0 0 4px rgba(47, 99, 255, 0.12);
  }

  .trip-textarea {
    min-height: 120px;
    resize: vertical;
  }

  .trip-form-section-title {
    margin: 6px 0 16px;
    font-size: 1.1rem;
    font-weight: 800;
    color: #17306e;
  }

  .trip-field--checkbox {
    justify-content: flex-end;
  }

  .trip-check {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 48px;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid #c9d7f0;
    background: #f8fbff;
    color: #17306e;
    font-weight: 600;
    cursor: pointer;
  }

  .trip-check input[type="checkbox"] {
    width: 18px;
    height: 18px;
  }

  .trip-form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 28px;
    flex-wrap: wrap;
  }

  .trip-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    border: none;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
  }

  .trip-btn:hover {
    transform: translateY(-1px);
  }

  .trip-btn--primary {
    background: #1e3dd8;
    color: #fff;
    box-shadow: 0 10px 24px rgba(30, 61, 216, 0.25);
  }

  .trip-btn--secondary {
    background: #eef3ff;
    color: #17306e;
    border: 1px solid #cddaf8;
  }

  .trip-btn--dark {
    background: #111827;
    color: #fff;
  }

  .trip-form-errors {
    margin-bottom: 20px;
    padding: 18px 20px;
    border-radius: 18px;
    background: #fff1f1;
    border: 1px solid #f2b8b8;
    color: #8a1c1c;
  }

  .trip-form-errors__title {
    font-weight: 800;
    margin-bottom: 10px;
  }

  .trip-form-errors ul {
    margin: 0;
    padding-left: 18px;
  }

  @media (max-width: 900px) {
    .trip-form-header {
      flex-direction: column;
      align-items: stretch;
    }

    .trip-form-grid,
    .trip-form-grid--compact {
      grid-template-columns: 1fr;
    }

    .trip-form-card {
      padding: 20px;
    }

    .trip-form-actions {
      justify-content: stretch;
    }

    .trip-btn {
      width: 100%;
    }
  }
</style>