<div class="subsection-page">
  <div class="subsection-card">
    <div class="report-item-header">
      <div>
        <div class="card-title">Importar Trechos Longos</div>
        <div class="card-subtitle">Envie um arquivo CSV com os dados de viagens.</div>
      </div>

      <%= link_to "Voltar", long_trips_path, class: "btn-secondary" %>
    </div>

    <%= form_with url: import_file_long_trips_path,
                  method: :post,
                  multipart: true,
                  local: true do |form| %>

      <div class="profile-line">
        <div class="profile-key">Arquivo CSV</div>
        <div class="profile-value">
          <%= form.file_field :file, accept: ".csv" %>
        </div>
      </div>

      <div style="margin-top: 20px;">
        <%= form.submit "Importar Dados", class: "btn-primary" %>
      </div>

    <% end %>
  </div>
</div>