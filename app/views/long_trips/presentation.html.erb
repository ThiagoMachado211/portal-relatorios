<div class="presentation-wrapper">
  <iframe
    id="presentationFrame"
    class="presentation-frame is-active"
    src="<%= dashboard_long_trips_path(page: @pages.first) %>">
  </iframe>
</div>

<script>
  (() => {
    const pages = <%= raw @pages.to_json %>;
    const frame = document.getElementById("presentationFrame");

    let current = 0;
    let intervalId = null;
    let isAutoMode = true;

    if (!frame || pages.length === 0) return;

    function currentDashboardUrl(page) {
      return "<%= dashboard_long_trips_path %>?page=" + encodeURIComponent(page);
    }

    function nextPage() {
      current = (current + 1) % pages.length;
      frame.src = currentDashboardUrl(pages[current]);
    }

    function startAutoMode() {
      stopAutoMode();
      isAutoMode = true;
      intervalId = setInterval(nextPage, 8000);
      console.log("Apresentação automática ativada");
    }

    function stopAutoMode() {
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
      isAutoMode = false;
      console.log("Apresentação automática pausada");
    }

    function toggleFullscreen() {
      const elem = document.documentElement;

      if (!document.fullscreenElement) {
        if (elem.requestFullscreen) {
          elem.requestFullscreen();
        }
      } else {
        if (document.exitFullscreen) {
          document.exitFullscreen();
        }
      }
    }

    window.addEventListener("message", function (event) {
      if (!event.data || !event.data.action) return;

      switch (event.data.action) {
        case "manualNavigation":
          stopAutoMode();
          break;
        case "autoNavigation":
          startAutoMode();
          break;
        case "fullscreen":
          toggleFullscreen();
          break;
        default:
          break;
      }
    });

    startAutoMode();
  })();
</script>