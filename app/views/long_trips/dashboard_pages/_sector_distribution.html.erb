<% pages = ["overview", "air_quantity", "land_quantity", "air_mileage", "land_mileage", "lead_time", "sector_distribution", "destination_cities", "destination_cities_monthly"] %>
<% current_index = pages.index(@page) || 0 %>
<% previous_page = current_index.positive? ? pages[current_index - 1] : nil %>
<% next_page = current_index < pages.length - 1 ? pages[current_index + 1] : nil %>

<div class="travel-dashboard-page">
  <div class="travel-dashboard-header">
    <h1>GESTÃO DE VIAGENS</h1>
    <h2><%= @dashboard_title %></h2>
  </div>

  <div class="dashboard-nav">
    <% if previous_page %>
      <%= link_to "← Anterior", dashboard_long_trips_path(page: previous_page), class: "dashboard-nav__button" %>
    <% else %>
      <span class="dashboard-nav__button dashboard-nav__button--disabled">← Anterior</span>
    <% end %>

    <%= link_to "Visão Geral", dashboard_long_trips_path(page: "overview"), class: "dashboard-nav__button" %>
    <%= link_to "Desativar Exibição", long_trips_path, class: "dashboard-nav__button dashboard-nav__button--danger" %>

    <% if next_page %>
      <%= link_to "Próxima →", dashboard_long_trips_path(page: next_page), class: "dashboard-nav__button" %>
    <% else %>
      <span class="dashboard-nav__button dashboard-nav__button--disabled">Próxima →</span>
    <% end %>
  </div>

  <div class="dashboard-chart-grid dashboard-chart-grid--single">
    <section class="dashboard-chart-panel dashboard-chart-panel--centered dashboard-chart-panel--wide">
      <div class="dashboard-chart-panel__header">
        <h2 class="dashboard-chart-panel__title"><%= @pie_title %></h2>
      </div>

      <% if @pie_data.any? %>
        <div class="pie-chart-wrapper pie-chart-wrapper--xl">
          <canvas id="sectorPieChart"></canvas>
        </div>
      <% else %>
        <div class="travel-empty-state">Nenhum dado disponível.</div>
      <% end %>
    </section>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const canvas = document.getElementById("sectorPieChart");
    const labels = <%= raw @pie_data.keys.to_json %>;
    const values = <%= raw @pie_data.values.to_json %>;

    if (canvas && labels.length > 0) {
      new Chart(canvas, {
        type: "pie",
        data: {
          labels: labels,
          datasets: [{
            data: values
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              position: "right",
              labels: {
                boxWidth: 18,
                padding: 16
              }
            },
            datalabels: {
              color: "#ffffff",
              font: {
                weight: "bold",
                size: 13
              },
              formatter: (value, context) => {
                const total = context.chart.data.datasets[0].data.reduce((a, b) => a + b, 0);
                const percentage = total > 0 ? ((value / total) * 100).toFixed(2) : "0.00";
                return percentage + "%";
              }
            }
          }
        },
        plugins: [ChartDataLabels]
      });
    }
  });
</script>