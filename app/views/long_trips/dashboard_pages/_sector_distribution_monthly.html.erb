<div class="travel-dashboard-page <%= 'tv-mode' if @display_mode == 'tv' %>">
  <div class="travel-dashboard-header">
    <h1>GESTÃO DE VIAGENS</h1>
    <h2><%= @dashboard_title %></h2>
  </div>

  <%= render "long_trips/dashboard_pages/navigation" %>

  <div class="monthly-city-grid">
    <% @monthly_sector_cards.each do |card| %>
      <section class="dashboard-chart-panel">
        <div class="dashboard-chart-panel__header">
          <h2 class="dashboard-chart-panel__title"><%= card[:title] %></h2>
        </div>

        <div class="column-chart">
          <% max_value = card[:data].values.max.to_f %>
          <% max_value = 1 if max_value <= 0 %>

          <% if card[:data].any? %>
            <% card[:data].each do |sector, value| %>
              <% height_percent = value.to_f > 0 ? (value.to_f / max_value) * 100 : 0 %>

              <div class="column-chart__item">
                <div class="column-chart__value"><%= value %></div>
                <div class="column-chart__bar-wrap">
                  <div class="column-chart__bar" style="height: <%= height_percent %>%"></div>
                </div>
                <div class="column-chart__label"><%= sector %></div>
              </div>
            <% end %>
          <% else %>
            <div class="travel-empty-state">Nenhum dado disponível.</div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>