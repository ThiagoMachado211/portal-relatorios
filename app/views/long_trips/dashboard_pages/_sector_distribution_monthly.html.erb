<% pages = ["overview", "air_quantity", "land_quantity", "air_mileage", "land_mileage", "lead_time", "sector_distribution", "sector_distribution_monthly", "destination_cities", "destination_cities_monthly"] %>
<% current_index = pages.index(@page) || 0 %>
<% previous_page = current_index.positive? ? pages[current_index - 1] : nil %>
<% next_page = current_index < pages.length - 1 ? pages[current_index + 1] : nil %>

<div class="travel-dashboard-page">
  <div class="travel-dashboard-header">
    <h1>GESTÃO DE VIAGENS</h1>
    <h2><%= @dashboard_title %></h2>
  </div>

  <div class="dashboard-nav">
    <% if previous_page %>
      <%= link_to "← Anterior", dashboard_long_trips_path(page: previous_page), class: "dashboard-nav__button" %>
    <% else %>
      <span class="dashboard-nav__button dashboard-nav__button--disabled">← Anterior</span>
    <% end %>

    <%= link_to "Visão Geral", dashboard_long_trips_path(page: "overview"), class: "dashboard-nav__button" %>

    <% if next_page %>
      <%= link_to "Próxima →", dashboard_long_trips_path(page: next_page), class: "dashboard-nav__button" %>
    <% else %>
      <span class="dashboard-nav__button dashboard-nav__button--disabled">Próxima →</span>
    <% end %>
  </div>

  <div class="monthly-city-grid">
    <% @monthly_sector_cards.each do |card| %>
      <section class="dashboard-chart-panel">
        <div class="dashboard-chart-panel__header">
          <h2 class="dashboard-chart-panel__title"><%= card[:title] %></h2>
        </div>

        <div class="travel-bar-chart">
          <% max_value = card[:data].values.max.to_f %>
          <% max_value = 1 if max_value <= 0 %>

          <% card[:data].each do |sector, value| %>
            <% width_percent = value.to_f > 0 ? (value.to_f / max_value) * 100 : 0 %>

            <div class="travel-bar-row">
              <div class="travel-bar-row__label"><%= sector %></div>
              <div class="travel-bar-row__track">
                <div class="travel-bar-row__bar <%= 'travel-bar-row__bar--zero' if value.to_f <= 0 %>" style="width: <%= width_percent %>%;">
                  <span class="travel-bar-row__value"><%= value %></span>
                </div>
              </div>
            </div>
          <% end %>

          <% if card[:data].empty? %>
            <div class="travel-empty-state">Nenhum dado disponível.</div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>