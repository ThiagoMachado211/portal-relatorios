<h1 style="margin-bottom:10px;"><%= @sidebar_section.title %></h1>
<p style="color:#64748b;margin-bottom:24px;">Selecione um relatório.</p>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
  <% @report_pages.each do |page| %>
    <div style="background:white;border-radius:16px;padding:22px;box-shadow:0 4px 14px rgba(0,0,0,0.08);border:1px solid #e5e7eb;">
      <h3 style="margin-top:0;margin-bottom:10px;font-size:20px;color:#0f172a;"><%= page.title %></h3>
      <p style="color:#475569;min-height:60px;">
        <%= page.description.presence || "Página de relatórios e documentos associados." %>
      </p>

      <%= link_to "Abrir relatório", report_page_path(page.slug),
          style: "display:inline-block;margin-top:10px;background:#2563eb;color:white;padding:10px 16px;border-radius:10px;text-decoration:none;font-weight:bold;" %>
    </div>
  <% end %>
</div>