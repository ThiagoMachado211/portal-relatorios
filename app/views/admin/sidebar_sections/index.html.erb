<div class="card">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <div>
      <div class="card-title">Seções da Sidebar</div>
      <div class="card-subtitle">Gerencie as seções exibidas no menu lateral</div>
    </div>

    <%= link_to "Nova Seção", new_admin_sidebar_section_path, class: "logout-button", style: "background:#2563eb;" %>
  </div>

  <table style="width:100%;border-collapse:collapse;">
    <thead>
      <tr style="text-align:left;border-bottom:1px solid #e5e7eb;color:black;">
        <th style="padding:12px; color:black;">Título</th>
        <th style="padding:12px; color:black;">Slug</th>
        <th style="padding:12px; color:black;">Posição</th>
        <th style="padding:12px; color:black;">Ativa</th>
        <th style="padding:12px; color:black;">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @sidebar_sections.each do |section| %>
        <tr style="border-bottom:1px solid #e5e7eb; color:black;">
          <td style="padding:12px; color:black;"><%= section.title %></td>
          <td style="padding:12px; color:black;"><%= section.slug %></td>
          <td style="padding:12px; color:black;"><%= section.position %></td>
          <td style="padding:12px; color:black;"><%= section.active ? "Sim" : "Não" %></td>
          <td style="padding:12px;display:flex;gap:8px;">
            <%= link_to "Editar", edit_admin_sidebar_section_path(section), class: "sidebar-link", style: "color:#2563eb;background:#eff6ff;" %>
            <%= button_to "Excluir", admin_sidebar_section_path(section), method: :delete, form: { style: "display:inline;" }, class: "logout-button", style: "padding:8px 12px;" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>