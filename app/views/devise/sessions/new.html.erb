<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg, #0f172a, #1e3a8a);padding:20px;">
  <div style="width:100%;max-width:430px;background:white;border-radius:20px;box-shadow:0 10px 30px rgba(0,0,0,0.25);padding:36px;">
    <div style="text-align:center;margin-bottom:28px;">
      <h1 style="margin:0;font-size:34px;color:#0f172a;">EstudoPlay</h1>
      <p style="margin-top:10px;color:#64748b;font-size:16px;">
        Acesse o portal de relatórios
      </p>
    </div>

    <%= form_for(resource,
                as: resource_name,
                url: session_path(resource_name),
                html: { data: { turbo: false } }) do |f| %>

      <div style="margin-bottom:18px;">
        <%= f.label :email, "E-mail", style: "display:block;margin-bottom:8px;font-weight:700;color:#334155;" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              style: "width:100%;padding:14px 16px;border:1px solid #cbd5e1;border-radius:12px;font-size:16px;box-sizing:border-box;" %>
      </div>

      <div style="margin-bottom:18px;">
        <%= f.label :password, "Senha", style: "display:block;margin-bottom:8px;font-weight:700;color:#334155;" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              style: "width:100%;padding:14px 16px;border:1px solid #cbd5e1;border-radius:12px;font-size:16px;box-sizing:border-box;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="margin-bottom:20px;display:flex;align-items:center;gap:8px;color:#475569;">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Lembrar acesso", style: "margin:0;" %>
        </div>
      <% end %>

      <%= f.submit "Entrar",
            style: "width:100%;background:#2563eb;color:white;border:none;border-radius:12px;padding:14px;font-size:18px;font-weight:700;cursor:pointer;" %>
    <% end %>

    <div style="margin-top:24px;text-align:center;color:#64748b;font-size:14px;">
      Portal seguro com controle por perfil de usuário
    </div>
  </div>
</div>